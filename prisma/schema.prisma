generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  phone         String         @unique
  full_name     String
  date_of_birth DateTime?
  created_at    DateTime       @default(now())
  emergencyCard EmergencyCard?
  reminders     Reminder[]
  medicines     Medicine[]
  familyMembers FamilyMember[]
}

model EmergencyCard {
  id                 String             @id @default(cuid())
  qr_code            String             @unique
  blood_type         String
  allergies          String[]
  medical_history    String[]
  current_medicines  String[]
  user               User               @relation(fields: [user_id], references: [id])
  user_id            String             @unique
  emergency_contacts EmergencyContact[]
}

model EmergencyContact {
  id                String        @id @default(cuid())
  name              String
  phone             String
  relation          String
  emergency_card    EmergencyCard @relation(fields: [emergency_card_id], references: [id])
  emergency_card_id String
}

model Reminder {
  id         String   @id @default(cuid())
  title      String
  time       String
  repeat     String?
  note       String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String
}

model Medicine {
  id         String   @id @default(cuid())
  name       String
  barcode    String?  @unique
  quantity   Int      @default(0)
  unit       String?
  note       String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String
}

model FamilyMember {
  id         String   @id @default(cuid())
  name       String
  phone      String?
  relation   String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String
}
